# =============================================================================
# Wedding Memories — copy to .env (never commit .env)
# =============================================================================

# Supabase Postgres
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Cloudflare R2
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="family-photos"
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
R2_PUBLIC_BASE_URL="https://pub-xxxxx.r2.dev"

# App
MEDIA_ROOT="./media/wedding"
NEXT_PUBLIC_APP_NAME="Wedding Memories"
GUEST_PASSWORD="change-me"
ADMIN_REINDEX_SECRET="change-me"
FAMILY_VIEW_TOKEN="long-random-token-for-family-link"
