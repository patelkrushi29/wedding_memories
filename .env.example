# =============================================================================
# Wedding Memories — environment variables
# Copy to .env and fill in. See docs/DEPLOY.md for production setup.
# =============================================================================

# --- Target production (Postgres + R2) — use these for go-live ---
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
# GUEST_PASSWORD="change-me-strong-password"
# FAMILY_VIEW_TOKEN="long-random-token-for-parents-link"
# ADMIN_REINDEX_SECRET="long-random-admin-secret"
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="wedding-media"
# R2_PUBLIC_BASE_URL="https://media.yourdomain.com"
# NEXT_PUBLIC_APP_NAME="Wedding Memories"

# --- Legacy local dev (until C1 Postgres ships in code) ---
DATABASE_URL="file:./dev.db"
MEDIA_ROOT="./media/wedding"
NEXT_PUBLIC_APP_NAME="Wedding Memories"
GUEST_PASSWORD="wedding"
ADMIN_REINDEX_SECRET="local-admin-secret"
